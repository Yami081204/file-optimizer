<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<SplitPane dividerPositions="0.3" prefHeight="600.0" prefWidth="900.0" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.fileoptimizer.app.controller.ExplorerController">
    <items>
        <VBox spacing="10.0" styleClass="sidebar-explorer">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <children>
                <Label styleClass="section-title" text="Folders" />
                <TreeView fx:id="folderTree" VBox.vgrow="ALWAYS" />
            </children>
        </VBox>

        <VBox spacing="10.0" styleClass="content-area">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <Label fx:id="currentPathLabel" styleClass="app-title" text="Select a folder..." />
                        <Region HBox.hgrow="ALWAYS" />
                        <TextField fx:id="searchField" promptText="Search files..." prefWidth="200.0" />
                    </children>
                </HBox>

                <TableView fx:id="fileTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="nameColumn" prefWidth="250.0" text="Name" />
                        <TableColumn fx:id="sizeColumn" prefWidth="100.0" text="Size" />
                        <TableColumn fx:id="typeColumn" prefWidth="120.0" text="Type" />
                        <TableColumn fx:id="dateColumn" prefWidth="180.0" text="Date Modified" />
                    </columns>
                    <placeholder>
                        <Label text="No files in this directory." />
                    </placeholder>
                </TableView>
            </children>
        </VBox>
    </items>
</SplitPane>
