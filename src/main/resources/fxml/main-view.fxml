<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Text?>

<BorderPane fx:id="mainRoot"
            prefHeight="750.0"
            prefWidth="1200.0"
            stylesheets="@../css/style.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.fileoptimizer.app.controller.MainController">

    <left>
        <VBox styleClass="sidebar" spacing="10">
            <children>

                <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="sidebar-brand">
                    <children>
                        <Circle radius="16.0" style="-fx-fill: -app-primary;" />
                        <Text style="-fx-font-size: 18; -fx-font-weight: 800; -fx-fill: -app-text-main;"
                              text="Optimizer" />
                    </children>
                </HBox>

                <VBox spacing="6.0" VBox.vgrow="ALWAYS">

                    <Button fx:id="btnDashboard"
                            maxWidth="Infinity"
                            onAction="#showDashboard"
                            styleClass="nav-button nav-button-active"
                            text="Dashboard" />

                    <Button fx:id="btnScan"
                            maxWidth="Infinity"
                            onAction="#showScan"
                            styleClass="nav-button"
                            text="Scan Files" />

                    <Button fx:id="btnDuplicates"
                            maxWidth="Infinity"
                            onAction="#showDuplicates"
                            styleClass="nav-button"
                            text="Duplicate Files" />

                    <Button fx:id="btnAutoClean"
                            maxWidth="Infinity"
                            onAction="#showAutoClean"
                            styleClass="nav-button"
                            text="Auto Clean" />

                    <Button fx:id="btnChat"
                            maxWidth="Infinity"
                            onAction="#showChat"
                            styleClass="nav-button"
                            text="AI Chat" />
                </VBox>

                <VBox spacing="10" alignment="CENTER">
                    <children>
                        <Label text="v1.0"
                               style="-fx-text-fill: -app-text-muted; -fx-font-size: 11;" />
                    </children>
                </VBox>

            </children>
        </VBox>
    </left>

    <center>
        <VBox>

            <HBox alignment="CENTER_LEFT" styleClass="header-bar" spacing="20">
                <children>

                    <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                        <Label fx:id="viewTitle"
                               styleClass="view-title"
                               text="Dashboard" />

                        <Label style="-fx-text-fill: -app-text-muted; -fx-font-size: 12;"
                               text="Home Directory" />
                    </VBox>

                    <HBox spacing="12">
                        <Button onAction="#handleExportReport"
                                styleClass="btn btn-outline"
                                text="Export" />

                        <Button onAction="#handleQuickScan"
                                styleClass="btn btn-primary"
                                text="Quick Scan" />
                    </HBox>

                </children>
            </HBox>

            <StackPane fx:id="contentArea"
                       styleClass="content-area"
                       VBox.vgrow="ALWAYS" />

        </VBox>
    </center>

</BorderPane>